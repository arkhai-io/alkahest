                    readonly "totalSupply()": {
                        readonly details: "Returns the value of tokens in existence.";
                    };
                    readonly "transfer(address,uint256)": {
                        readonly details: "See {IERC20-transfer}. Requirements: - `to` cannot be the zero address. - the caller must have a balance of at least `value`.";
                    };
