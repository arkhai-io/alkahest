# Compiler files (contracts)
contracts/cache/
contracts/out/
contracts/target/
**/target/

# Ignores development broadcast logs
!/contracts/broadcast
/contracts/broadcast/*/31337/
/contracts/broadcast/**/dry-run/

# Deployment artifacts (only chain-named JSONs are tracked)
contracts/deployments/deployment_[0-9]*.json
contracts/deployments/*.txt

# Dotenv files
.env
contracts/.env
contracts/script/.env

# Dependencies
node_modules/

# Build artifacts
*.rdb
.DS_Store
__pycache__/
.pytest_cache/

# Development tools
.aider*
summary.txt
notes
notes.md
